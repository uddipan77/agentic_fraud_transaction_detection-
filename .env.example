# Copy this file to `.env` at the repo root and fill in your own keys.
# `.env` is gitignored — it must NEVER be committed.

# ── Langfuse (used by variants 1 and 3) ──────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://challenges.reply.com/langfuse

# ── OpenRouter (used by variants 1 and 3) ────────────────────────────
OPENROUTER_API_KEY=

# ── Groq (used by variant 2 only) ────────────────────────────────────
GROQ_API_KEY=

# ── Team identity (prefix for Langfuse session IDs) ──────────────────
# Spaces are auto-replaced with "-" in session IDs.
TEAM_NAME=
